{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Boards",
  "version": "0.1.0",
  "identifier": "com.codexboards.desktop",
  "build": {
    "beforeDevCommand": "bun run --filter @codex-boards/web dev -- --host 127.0.0.1 --port 5173",
    "beforeBuildCommand": "bun run --filter @codex-boards/web build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Boards",
        "width": 1440,
        "height": 960,
        "minWidth": 1080,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "dmg"],
    "icon": ["icons/icon.png", "icons/128x128.png"],
    "resources": ["resources/backend/codex-boards-backend"]
  }
}
