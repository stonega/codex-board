<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.codexboards.Gnome</id>
  <name>Codex Boards</name>
  <summary>Native GNOME project boards for local Codex rollout history</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <developer id="com.codexboards">
    <name>Codex Boards contributors</name>
  </developer>
  <url type="homepage">https://github.com/stonega/codex-boards</url>
  <description>
    <p>
      Codex Boards turns local Codex rollout history into a project-oriented
      issue workspace with native GNOME controls for projects, filters, sync,
      parser settings, sync history, review triage, and Multica export.
    </p>
  </description>
  <launchable type="desktop-id">com.codexboards.Gnome.desktop</launchable>
  <provides>
    <binary>codex-boards-gnome</binary>
  </provides>
  <content_rating type="oars-1.1" />
  <releases>
    <release version="0.1.0" date="2026-05-17" />
  </releases>
</component>
